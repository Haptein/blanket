#: data/com.rafaelmardojai.Blanket.metainfo.xml.in:9
msgid ""
"Improve focus and increase your productivity by listening to different "
"ambient sounds"
msgstr ""
"Whakapaihia tō arotahi me te whakanui i tō whaihua mā te whakarongo ki ngā "
"momo oro taiao rerekē"

